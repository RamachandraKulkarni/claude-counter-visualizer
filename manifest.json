{
  "manifest_version": 3,
  "name": "Claude Counter",
  "version": "0.7.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "{236c6889-52b6-4454-bc4b-5a2ad18effa2}",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "description": "Shows ~token count, cache timer, native session/weekly bars, a pre-send cost estimator, time-to-cap forecast, and a popup dashboard.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "action": {
    "default_title": "Claude Counter",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "contextMenus"
  ],
  "commands": {
    "pin-focused-message": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Pin the currently hovered or focused message"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "css": [
        "src/styles.css"
      ],
      "js": [
        "src/content/constants.js",
        "src/content/utils/errors.js",
        "src/content/utils/cleanup.js",
        "src/content/utils/retry.js",
        "src/content/utils/db.js",
        "src/content/utils/messaging.js",
        "src/content/utils/worker-tokenizer.js",
        "src/content/bridge-client.js",
        "src/vendor/o200k_base.js",
        "src/content/model-detect.js",
        "src/content/tokens.js",
        "src/content/burn-rate.js",
        "src/content/forecast.js",
        "src/content/model-stats.js",
        "src/content/ui.js",
        "src/content/estimator.js",
        "src/content/pin.js",
        "src/content/injection.js",
        "src/content/main.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/bridge.js",
        "src/workers/tokenizer.worker.js",
        "src/vendor/o200k_base.js",
        "src/forensics/index.html",
        "src/forensics/forensics.js",
        "src/forensics/forensics.css"
      ],
      "matches": [
        "https://claude.ai/*"
      ]
    }
  ]
}
